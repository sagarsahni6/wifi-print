<Window x:Class="WifiPrintServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WiFi Print Server" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        MinWidth="900" MinHeight="600"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════ Sidebar ══════════════════ -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo at top -->
                <StackPanel DockPanel.Dock="Top" Margin="24,28,24,32">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖨️" FontSize="26" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="WiFi Print" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="Server Dashboard" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Server Status at bottom -->
                <Border DockPanel.Dock="Bottom" Margin="16,0,16,20"
                        Background="{StaticResource BgInputBrush}" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse Width="10" Height="10" Fill="#66BB6A" Margin="0,0,8,0"
                                     x:Name="StatusDot"/>
                            <TextBlock x:Name="StatusText" Text="Online"
                                       Foreground="#66BB6A" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>
                        <TextBlock x:Name="IpText" Text="IP: Loading..."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                        <TextBlock x:Name="PortText" Text="Port: 5000"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Nav Items -->
                <StackPanel Margin="8,0">
                    <RadioButton x:Name="NavDashboard" Content="📊  Dashboard"
                                 Style="{StaticResource NavItem}"
                                 IsChecked="True" Checked="Nav_Checked" Tag="Dashboard"/>
                    <RadioButton x:Name="NavJobs" Content="📋  Print Queue"
                                 Style="{StaticResource NavItem}"
                                 Checked="Nav_Checked" Tag="Jobs"/>
                    <RadioButton x:Name="NavPrinters" Content="🖨️  Printers"
                                 Style="{StaticResource NavItem}"
                                 Checked="Nav_Checked" Tag="Printers"/>
                    <RadioButton x:Name="NavDevices" Content="📱  Devices"
                                 Style="{StaticResource NavItem}"
                                 Checked="Nav_Checked" Tag="Devices"/>
                    <RadioButton x:Name="NavLogs" Content="📝  Logs"
                                 Style="{StaticResource NavItem}"
                                 Checked="Nav_Checked" Tag="Logs"/>
                    <RadioButton x:Name="NavSettings" Content="⚙️  Settings"
                                 Style="{StaticResource NavItem}"
                                 Checked="Nav_Checked" Tag="Settings"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ══════════════════ Main Content ══════════════════ -->
        <Grid Grid.Column="1" Margin="28,24,28,20">

            <!-- ── Dashboard Page ── -->
            <Grid x:Name="DashboardPage" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Server overview and quick actions"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Stats Cards -->
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Active Jobs" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock x:Name="ActiveJobsCount" Text="0" FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Completed" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock x:Name="CompletedCount" Text="0" FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Printers" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock x:Name="PrinterCount" Text="0" FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Paired Devices" Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12" Margin="0,0,0,8"/>
                            <TextBlock x:Name="DeviceCount" Text="0" FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Pairing + Recent Jobs -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Device Approval Card -->
                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="📱" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="Device Connections" FontSize="17" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="When a phone requests to connect, approve it here."
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                                       TextWrapping="Wrap" Margin="0,0,0,20"/>

                            <!-- Approval Notification (hidden by default) -->
                            <Border x:Name="ApprovalBanner" Background="#FFF3E0" CornerRadius="12"
                                    Padding="20,16" Margin="0,0,0,12" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="📲 Connection Request" FontSize="15" FontWeight="SemiBold"
                                               Foreground="#E65100" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="ApprovalDeviceName" Text="" FontSize="14"
                                               Foreground="#BF360C" FontWeight="Medium" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ApprovalDeviceIp" Text="" FontSize="12"
                                               Foreground="#E65100" Margin="0,0,0,16"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="✓ Allow" Style="{StaticResource ModernButton}"
                                                Click="ApproveDevice_Click" Padding="24,10" Margin="0,0,12,0"
                                                Background="#43A047"/>
                                        <Button Content="✗ Deny" Padding="24,10"
                                                Click="DenyDevice_Click"
                                                Background="#EF5350" Foreground="White" FontWeight="SemiBold"
                                                BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Idle state -->
                            <Border x:Name="ApprovalIdle" Background="{StaticResource BgInputBrush}"
                                    CornerRadius="12" Padding="20,24" HorizontalAlignment="Stretch">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="✓" FontSize="32" HorizontalAlignment="Center"
                                               Foreground="#66BB6A" Margin="0,0,0,8"/>
                                    <TextBlock Text="Waiting for connection requests..."
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Recent Jobs -->
                    <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="📋" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="Recent Jobs" FontSize="17" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <ListView x:Name="RecentJobsList" Background="Transparent"
                                      BorderThickness="0" MaxHeight="300">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BgInputBrush}" CornerRadius="8"
                                                Padding="12,10" Margin="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📄" FontSize="14" Margin="0,0,10,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding OriginalFileName}" Width="170"
                                                           TextTrimming="CharacterEllipsis" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Border CornerRadius="10" Padding="10,4" Margin="8,0,0,0"
                                                        Background="#E8EAF6">
                                                    <TextBlock Text="{Binding Status}" FontSize="11"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ── Jobs Page ── -->
            <Grid x:Name="JobsPage" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Print Queue" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage all print jobs" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
                    <ListView x:Name="JobsList" Background="Transparent"
                              BorderThickness="0" Padding="8">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" DisplayMemberBinding="{Binding Id}" Width="100"/>
                                <GridViewColumn Header="File" DisplayMemberBinding="{Binding OriginalFileName}" Width="200"/>
                                <GridViewColumn Header="Printer" DisplayMemberBinding="{Binding PrinterName}" Width="150"/>
                                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="100"/>
                                <GridViewColumn Header="Progress" DisplayMemberBinding="{Binding Progress}" Width="80"/>
                                <GridViewColumn Header="Created" DisplayMemberBinding="{Binding CreatedAt}" Width="160"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Border>
            </Grid>

            <!-- ── Printers Page ── -->
            <Grid x:Name="PrintersPage" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Installed Printers" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Printers available on this PC" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <ListView x:Name="PrintersList" Grid.Row="1" Background="Transparent"
                          BorderThickness="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgCardBrush}" CornerRadius="12"
                                    Padding="20" Margin="0,4" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                            Background="{StaticResource PrimaryLightBrush}" Margin="0,0,16,0">
                                        <TextBlock Text="🖨️" FontSize="20" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                                   Margin="0,3,0,0">
                                            <Run Text="Driver: "/><Run Text="{Binding DriverName}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Border Grid.Column="2" CornerRadius="16" Padding="12,6"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Fill="#66BB6A" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Status}" FontSize="12"
                                                       Foreground="#388E3C" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- ── Devices Page ── -->
            <Grid x:Name="DevicesPage" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Paired Devices" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage connected Android devices — block, unblock, or remove"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DevicesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgCardBrush}" CornerRadius="12"
                                        Padding="20" Margin="0,4" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Device Icon -->
                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                                Background="{StaticResource PrimaryLightBrush}" Margin="0,0,16,0">
                                            <TextBlock Text="📱" FontSize="20" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- Device Info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                                       Margin="0,3,0,0">
                                                <Run Text="IP: "/><Run Text="{Binding IpAddress}"/>
                                                <Run Text="  •  Paired: "/><Run Text="{Binding PairedAt, StringFormat='{}{0:g}'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <!-- Action Buttons -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Content="🔓 Unblock" Padding="12,6" Margin="4,0"
                                                    Click="UnblockDevice_Click" Tag="{Binding Id}"
                                                    Visibility="{Binding IsBlocked, Converter={StaticResource BoolToVisibility}}"
                                                    Background="#43A047" Foreground="White" FontWeight="SemiBold"
                                                    BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="🚫 Block" Padding="12,6" Margin="4,0"
                                                    Click="BlockDevice_Click" Tag="{Binding Id}"
                                                    Visibility="{Binding IsBlocked, Converter={StaticResource InverseBoolToVisibility}}"
                                                    Background="#FF9800" Foreground="White" FontWeight="SemiBold"
                                                    BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="🗑️ Remove" Padding="12,6" Margin="4,0"
                                                    Click="RemoveDevice_Click" Tag="{Binding Id}"
                                                    Background="#EF5350" Foreground="White" FontWeight="SemiBold"
                                                    BorderThickness="0" Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ── Logs Page ── -->
            <Grid x:Name="LogsPage" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Server Logs" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Real-time server activity" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="0">
                    <TextBox x:Name="LogsTextBox" Background="{StaticResource BgInputBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Cascadia Code, Consolas"
                             FontSize="12" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap" BorderThickness="0" Padding="16"
                             Text="Server logs will appear here..."/>
                </Border>
            </Grid>

            <!-- ── Settings Page ── -->
            <Grid x:Name="SettingsPage" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Configure server preferences" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" VerticalAlignment="Top">
                    <StackPanel MaxWidth="480" HorizontalAlignment="Left">
                        <TextBlock Text="Default Printer" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                        <ComboBox x:Name="DefaultPrinterCombo" Margin="0,0,0,20"
                                  FontSize="13" Padding="10,8"/>

                        <TextBlock Text="Server Port" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                        <TextBox x:Name="PortInput" Text="5000" Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,20"/>

                        <TextBlock Text="Server Name" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" FontWeight="Medium" Margin="0,0,0,6"/>
                        <TextBox x:Name="ServerNameInput" Style="{StaticResource ModernTextBox}"
                                 Margin="0,0,0,24"/>

                        <CheckBox x:Name="AutoStartCheck" Content="Start on system boot"
                                  Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                  Margin="0,0,0,12"/>
                        <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to system tray"
                                  Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"
                                  IsChecked="True" Margin="0,0,0,28"/>

                        <Button Content="Save Settings" Style="{StaticResource ModernButton}"
                                Click="SaveSettings_Click" HorizontalAlignment="Left" Padding="28,12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
